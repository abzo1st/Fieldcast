{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "lib": ["ESNext", "DOM"],
      "types": ["vite/client"],
      "jsx": "react-jsx",
      "strict": true,
      "skipLibCheck": true,
      "noEmit": true
    },
    "include": ["src/**/*"]
  }